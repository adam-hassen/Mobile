<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Certificats pour le fournisseur Google Fonts (com.google.android.gms.fonts).
        Pour régénérer ce fichier automatiquement avec les vrais certificats :
        Dans Android Studio : res > New > Font Resource File > sélectionner "Downloadable"
        pour Nunito ou Inter. Android Studio génère automatiquement ce fichier complet.
        Sans certificats valides, l'app utilise la police système par défaut (Roboto).
    -->
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>
    <string-array name="com_google_android_gms_fonts_certs_dev">
    </string-array>
    <string-array name="com_google_android_gms_fonts_certs_prod">
    </string-array>
</resources>
